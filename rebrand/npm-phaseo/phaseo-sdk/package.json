{
  "name": "@phaseo/sdk",
  "version": "2.0.5",
  "description": "Phaseo Gateway SDK transition package for TypeScript and JavaScript.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js",
      "require": "./dist/devtools/index.cjs"
    },
    "./compat/openai": {
      "types": "./dist/compat/openai.d.ts",
      "import": "./dist/compat/openai.js",
      "require": "./dist/compat/openai.cjs"
    },
    "./compat/anthropic": {
      "types": "./dist/compat/anthropic.d.ts",
      "import": "./dist/compat/anthropic.js",
      "require": "./dist/compat/anthropic.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@ai-stats/sdk": "2.0.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaseoteam/Phaseo.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
