{
  "name": "phaseo",
  "version": "2.0.5",
  "description": "Phaseo Gateway SDK transition package.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "phaseo": "bin/phaseo.js"
  },
  "exports": {
    ".": {
