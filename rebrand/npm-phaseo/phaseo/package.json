    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@ai-stats/cli": "0.1.1",
    "@ai-stats/sdk": "2.0.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaseoteam/Phaseo.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
