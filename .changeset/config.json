{
	"$schema": "https://unpkg.com/@changesets/config@2.0.0/schema.json",
	"changelog": [
		"@changesets/changelog-github",
		{
			"repo": "phaseoteam/Phaseo"
		}
	],
	"commit": false,
	"access": "public",
	"baseBranch": "main",
	"ignore": ["phaseo", "@phaseo/devtools", "@phaseo/devtools-core"],
	"updateInternalDependencies": "patch",
	"privatePackages": {
		"version": true,
		"tag": false
	}
}
