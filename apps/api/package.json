{
	"name": "@ai-stats/gateway-api",
	"version": "1.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "npx wrangler dev",
		"build": "npx wrangler deploy --dry-run",
		"start": "npx wrangler dev",
		"lint": "eslint . && pnpm run typecheck",
		"typecheck": "tsc --noEmit",
		"simulate:pricing": "tsx scripts/pricing-simulator.tsx --all",
		"simulate:pricing:test": "tsx scripts/test-pricing/pricing-simulator-harness.ts",
		"test": "pnpm exec vitest run",
		"test:aimock": "tsx scripts/run-aimock-tests.ts",
		"test:aimock:record": "tsx scripts/run-aimock-tests.ts --record",
		"test:live": "pnpm exec vitest run tests/integration/openai-gpt5-nano.live.spec.ts",
		"test:live:gpt5-4-mini-nano": "pnpm exec vitest run tests/integration/openai-gpt5-4-mini-nano.live.spec.ts",
		"test:live:gpt5-4-nano-tools": "pnpm exec vitest run tests/integration/openai-gpt5-4-nano-tools.live.spec.ts",
		"test:live:media": "pnpm exec vitest run tests/integration/multimodal-media.live.spec.ts",
		"test:live:active": "pnpm exec vitest run tests/integration/active-providers.live.spec.ts",
		"test:live:text-modern": "pnpm exec vitest run tests/integration/text-modern-features.live.spec.ts",
		"test:live:stream-tools": "pnpm exec vitest run tests/integration/stream-tools.live.spec.ts",
		"test:live:gpt54-nano-text": "pnpm exec vitest run tests/integration/gpt54-nano-text-surfaces.live.spec.ts",
		"test:live:deepseek-v4-flash": "pnpm exec vitest run tests/integration/deepseek-v4-flash-providers.live.spec.ts",
		"test:live:embeddings-moderation": "pnpm exec vitest run tests/integration/embeddings-moderation.live.spec.ts",
		"test:live:audio-images": "pnpm exec vitest run tests/integration/audio-images.live.spec.ts",
		"test:live:video-batch": "pnpm exec vitest run tests/integration/video-batch.live.spec.ts",
		"test:live:targeted": "tsx scripts/run-live-targeted-tests.ts",
		"test:live:provider-endpoint-matrix": "pnpm exec vitest run tests/integration/provider-endpoint-matrix.live.spec.ts",
		"test:live:provider": "tsx scripts/run-live-provider-tests.ts",
		"test:live:provider:arcee": "tsx scripts/run-live-provider-tests.ts --provider arcee",
		"test:live:provider:baseten": "tsx scripts/run-live-provider-tests.ts --provider baseten",
		"test:live:provider:chutes": "tsx scripts/run-live-provider-tests.ts --provider chutes",
		"test:live:provider:cohere": "tsx scripts/run-live-provider-tests.ts --provider cohere",
		"test:live:provider:cohere:chat": "tsx scripts/run-live-provider-tests.ts --provider cohere --scenarios chat_nonstream_hi,chat_stream_hi,chat_nonstream_tool,chat_nonstream_structured,messages_nonstream_hi,messages_nonstream_tool,messages_nonstream_structured",
		"test:live:provider:deepinfra": "tsx scripts/run-live-provider-tests.ts --provider deepinfra",
		"test:live:provider:together": "tsx scripts/run-live-provider-tests.ts --provider together",
		"test:live:provider:together:chat": "tsx scripts/run-live-provider-tests.ts --provider together --scenarios chat_nonstream_hi,chat_stream_hi,chat_nonstream_tool,chat_nonstream_structured,messages_nonstream_hi,messages_nonstream_tool,messages_nonstream_structured",
		"test:live:all-providers": "tsx scripts/run-live-provider-tests.ts --all-providers",
		"test:live:all-api-providers": "tsx scripts/run-live-provider-tests.ts --all-api-providers",
		"test:live:provider:alpha-beta": "tsx scripts/run-live-provider-tests-alpha-beta.ts",
		"test:live:nano-banana": "pnpm exec vitest run tests/integration/nano-banana-image.live.spec.ts",
		"test:live:video:sora": "tsx scripts/sora-video-live.ts",
		"report:missing-discovered-models": "tsx scripts/report-missing-discovered-models.ts"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.106.2",
		"@upstash/redis": "^1.38.0",
		"@visulima/tabular": "^3.1.0",
		"hono": "^4.12.27",
		"ink": "^7.0.0",
		"react": "^19.2.7",
		"stripe": "^22.1.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@anthropic-ai/sdk": "^0.91.1",
		"@cloudflare/workers-types": "^4.20260523.1",
		"@copilotkit/aimock": "1.15.1",
		"dotenv": "^17.4.2",
		"eslint": "^10.4.0",
		"openai": "^6.39.0",
		"tsx": "^4.20.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.7",
		"wrangler": "^4.94.0"
	}
}
