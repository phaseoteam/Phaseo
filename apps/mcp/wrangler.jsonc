{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "phaseo-mcp-preview",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-08",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "secrets": {
    "required": ["PHASEO_MCP_RESOURCE_SERVER_SECRET"]
  },
  "observability": {
    "enabled": true,
    "logs": { "head_sampling_rate": 1 },
    "traces": { "enabled": true, "head_sampling_rate": 0.01 }
  },
  "vars": {
    "PHASEO_API_BASE_URL": "https://api.phaseo.app"
  },
  "env": {
    "production": {
      "name": "phaseo-mcp",
      "workers_dev": false,
      "secrets": {
        "required": ["PHASEO_MCP_RESOURCE_SERVER_SECRET"]
      },
      "routes": [
        { "pattern": "mcp.phaseo.app", "custom_domain": true }
      ],
      "services": [
        { "binding": "PHASEO_API", "service": "phaseo-gateway" }
      ],
      "vars": {
        "PHASEO_API_BASE_URL": "https://api.phaseo.app"
      }
    }
  }
}
