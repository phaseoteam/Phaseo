{
  "name": "@phaseo/devtools-viewer",
  "description": "Web-based viewer for Phaseo DevTools telemetry",
  "version": "0.2.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "phaseo-devtools": "./dist/cli/index.js"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist public",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "build": "pnpm run build:ui && pnpm run build:server",
    "prepublishOnly": "pnpm run build",
    "dev:server": "pnpm exec tsx watch src/server/index.ts -- --start --port 4984 --dir ../../../.phaseo-devtools",
    "dev:ui": "pnpm exec wait-on tcp:4984 && vite --port 4983",
    "dev": "node dev-start.mjs",
    "dev:old": "concurrently \"pnpm run dev:server\" \"pnpm run dev:ui\"",
    "start": "node dist/cli/index.js start",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.100.14",
    "clsx": "^2.1.1",
    "hono": "^4.12.27",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.14",
    "rimraf": "^6.0.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/phaseoteam/Phaseo"
  },
  "publishConfig": {
    "access": "public"
  }
}
