{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "types": ["node"],
    "typeRoots": ["../sdk-ts/node_modules/@types"],
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
