{
	"name": "@phaseo/sdk",
	"description": "Phaseo Gateway SDK for TypeScript/JavaScript",
	"version": "2.0.5",
	"type": "module",
	"private": false,
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./devtools": {
			"types": "./dist/devtools/index.d.ts",
			"import": "./dist/devtools/index.js",
			"require": "./dist/devtools/index.cjs"
		},
		"./compat/openai": {
			"types": "./dist/compat/openai.d.ts",
			"import": "./dist/compat/openai.js",
			"require": "./dist/compat/openai.cjs"
		},
		"./compat/anthropic": {
			"types": "./dist/compat/anthropic.d.ts",
			"import": "./dist/compat/anthropic.js",
			"require": "./dist/compat/anthropic.cjs"
		}
	},
	"files": [
		"dist",
		"SKILL.md",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"scripts": {
		"clean": "rimraf dist src/oapi-gen",
		"gen": "pnpm -w oapi:gen:ts",
		"build": "rimraf dist && tsc -p tsconfig.build.json",
		"prepublishOnly": "pnpm run build",
		"postinstall": "node scripts/postinstall.cjs",
		"test:unit": "pnpm exec vitest run tests/client-async-jobs.test.ts tests/client-batches.test.ts tests/client-chat.test.ts tests/client-endpoints.test.ts tests/client-files.test.ts tests/client-video.test.ts tests/devtools.test.ts tests/webhooks.test.ts",
		"test:smoke": "pnpm smoke:all",
		"smoke:chat": "dotenv -e .env.local -- tsx tests/smoke.ts --operation chat",
		"smoke:responses": "dotenv -e .env.local -- tsx tests/smoke.ts --operation responses",
		"smoke:compat-openai": "dotenv -e .env.local -- tsx tests/compat-openai.ts",
		"smoke:compat-anthropic": "dotenv -e .env.local -- tsx tests/compat-anthropic.ts",
		"smoke:all": "pnpm smoke:responses && pnpm smoke:chat && pnpm smoke:compat-openai && pnpm smoke:compat-anthropic",
		"test": "pnpm test:unit",
		"pack:dry": "npm pack --dry-run"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"rimraf": "^6.0.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.7.0",
		"typescript": "^6.0.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/phaseoteam/Phaseo.git"
	},
	"publishConfig": {
		"access": "public"
	}
}
