<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>

    <PackageId>AI.Stats.Sdk</PackageId>
    <Version>1.2.0</Version>
    <Authors>AI Stats</Authors>
    <Company>AI Stats</Company>
    <Description>Official AI Stats SDK for .NET.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://docs.ai-stats.phaseo.app</PackageProjectUrl>
    <RepositoryUrl>https://github.com/AI-Stats/AI-Stats</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>ai;sdk;llm;gateway</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Client.cs" />
    <Compile Include="Devtools.cs" />
    <Compile Include="src\gen\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
