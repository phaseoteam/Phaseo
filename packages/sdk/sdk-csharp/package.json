{
	"name": "@phaseo/csharp-sdk",
	"version": "2.0.4",
	"private": true,
	"description": "Phaseo C# SDK (preview) - generated client with models wrapper",
	"license": "MIT",
	"scripts": {
		"postinstall": "node ../scripts/postinstall-viewer-prompt.cjs @phaseo/csharp-sdk",
		"build": "dotnet build Phaseo.Sdk.csproj -c Release",
		"test": "dotnet test tests/Phaseo.Sdk.Tests/Phaseo.Sdk.Tests.csproj -c Release",
		"pack": "dotnet pack Phaseo.Sdk.csproj -c Release -o artifacts",
		"smoke:chat": "dotenv -e .env.local -- dotnet run --project tests/SmokeChat/SmokeChat.csproj",
		"smoke:responses": "dotenv -e .env.local -- dotnet run --project tests/SmokeChat/SmokeChat.csproj -- responses",
		"smoke:responses:sdk": "dotenv -e .env.local -- dotnet run --project tests/SmokeChat/SmokeChat.csproj -- responses"
	}
}
