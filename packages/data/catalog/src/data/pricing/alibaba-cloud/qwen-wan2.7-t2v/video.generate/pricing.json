      "unit": "second",
      "unit_size": 1,
      "price_per_unit": 0.733924,
      "currency": "CNY",
      "tiering_mode": null,
      "pricing_plan": "standard",
      "note": "International deployment",
      "match": [
        {
          "path": "video_params.resolution",
          "op": "in",
          "or_group": 1,
