      "unit": "second",
      "unit_size": 1,
      "price_per_unit": 1.100886,
      "currency": "CNY",
      "tiering_mode": null,
      "pricing_plan": "standard",
      "note": "International deployment",
      "match": [
        {
          "path": "video_params.resolution",
          "op": "in",
          "or_group": 1,
