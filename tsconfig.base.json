{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"noImplicitAny": false,
		"strictNullChecks": false,
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"@ui/*": ["packages/ui/src/*"]
		}
	}
}
